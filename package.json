{
  "name": "tiny-agent",
  "version": "1.0.0",
  "description": "Mini transparent agent with skill layering",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:cars": "tsx toolkits/run.ts cars",
    "dev:fridge": "tsx toolkits/run.ts fridge",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "smoke": "tsx tests/smoke.ts",
    "test:robot-ab": "tsx tests/robot-a-to-b.ts",
    "smoke:mock": "TINY_AGENT_MOCK_LLM=1 TINY_AGENT_MOCK_LLM_MODULE=examples/agent-mocks/genericMockLlmFetch.ts tsx tests/smoke.ts",
    "dev:mock": "TINY_AGENT_MOCK_LLM=1 TINY_AGENT_MOCK_LLM_MODULE=examples/agent-mocks/genericMockLlmFetch.ts tsx src/index.ts",
    "dev:mock:demo": "TINY_AGENT_MOCK_LLM=1 TINY_AGENT_MOCK_LLM_MODULE=examples/agent-mocks/laundryCarMockFetch.ts tsx toolkits/run.ts cars",
    "example:tiny": "tsx examples/tiny-agent-example.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@langchain/core": "^1.1.42",
    "@langchain/ollama": "^1.2.7",
    "@langchain/openai": "^1.4.5",
    "langchain": "^1.3.5",
    "openai": "^6.35.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
